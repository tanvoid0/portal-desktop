{
  "name": "portal-desktop",
  "private": true,
  "version": "0.4.0",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "scripts": {
    "predev": "npx kill-port 1420 || echo 'Port 1420 not in use'",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint src && node scripts/check-shadcn-ui.mjs",
    "test:unit": "vitest",
    "test": "pnpm test:unit -- --run && pnpm test:e2e",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "n8n:start": "cd n8n-workflows && npx n8n start",
    "n8n:dev": "cd n8n-workflows && npx n8n start --tunnel",
    "ollama:install": "curl -fsSL https://ollama.ai/install.sh | sh",
    "ollama:models": "ollama pull llama3.2:3b && ollama pull codellama:7b && ollama pull mistral:7b",
    "ollama:serve": "ollama serve",
    "ai:setup": "pnpm ollama:install && pnpm ollama:models",
    "ai:test": "node test-ollama-integration.js",
    "run:install": "node scripts/install.js",
    "postrun:install": "echo 'Installation complete - no build tools required'",
    "postupdate": "cargo update --manifest-path src-tauri/Cargo.toml",
    "release:prepare": "node scripts/prepare-release.mjs"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.17.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/table-core": "^8.21.3",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.1",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "embla-carousel-svelte": "^8.6.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "formsnap": "^2.0.1",
    "globals": "^17.6.0",
    "kill-port": "^2.0.1",
    "layerchart": "2.0.0-next.27",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "4.0.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "sveltekit-superforms": "^2.30.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-browser-svelte": "^2.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ]
  },
  "dependencies": {
    "@battlefieldduck/xterm-svelte": "^2.3.0",
    "@iconify/svelte": "^5.2.1",
    "@tanstack/svelte-query": "^6.1.34",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@types/qrcode": "^1.5.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "qrcode": "^1.5.4",
    "ws": "^8.21.0"
  }
}
